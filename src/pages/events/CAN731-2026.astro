---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pastActions = [
  {
    code: "OTT313",
    city: "Ottawa",
    cityZh: "渥太华",
    venue: "Parliament Hill",
    venueZh: "国会山",
    date: "March 13, 2026",
    dateZh: "2026年3月13日",
    count: "313",
    href: "/events/OTT313-2026",
  },
  {
    code: "VAN501",
    city: "Vancouver",
    cityZh: "温哥华",
    venue: "Vancouver Art Gallery → IRCC Office",
    venueZh: "温哥华美术馆 → IRCC 办公室",
    date: "May 1, 2026",
    dateZh: "2026年5月1日",
    count: "501",
    href: "/events/VAN501-2026",
  },
  {
    code: "TOR528",
    city: "Mississauga",
    cityZh: "密西沙加",
    venue: "IRCC Office",
    venueZh: "IRCC 办公室",
    date: "May 28, 2026",
    dateZh: "2026年5月28日",
    count: "528",
    href: "/events/TOR528-2026",
  },
];

const supportVoices = [
  { name: "Senator Yuen Pau Woo", role: "Independent Senators Group, British Columbia", href: "https://x.com/VoicesFairCheck/status/2050339512900051347?s=20" },
  { name: "Former Senator Victor Oh", role: "Ontario", href: "https://x.com/VoicesFairCheck/status/2050338840523739215?s=20" },
  { name: "Don Davies", role: "Member of Parliament", href: "https://x.com/voicesfaircheck/status/2051010420245492222?s=46" },
  { name: "Christine Boyle", role: "Member of the Legislative Assembly of British Columbia", href: "https://x.com/voicesfaircheck/status/2051015286065951184?s=46" },
  { name: "Steven Meurrens", role: "Immigration Lawyer", href: "https://x.com/smeurrens/status/2050265045465186374" },
  { name: "Joshua Slayen", role: "Immigration Lawyer", href: "https://x.com/VoicesFairCheck/status/2050338177471389701?s=20" },
];

const campaignMaterials = [
  {
    src: "/events/can731-2026/photos/isNotJust.png",
    alt: "Security without transparency is not just, it's harmful — the current security screening system is failing on transparency, fairness, efficiency, and supervision.",
    captionEn: "Security without transparency is not just — it's harmful. The current system fails on transparency, fairness, efficiency, and oversight, driving away skilled talent and wasting public resources.",
    captionZh: "缺乏透明度的安全审查并不公正——而是有害的。当前系统在透明度、公平性、效率与监督上均存在缺失，正在赶走优秀人才、浪费公共资源。",
    captionFr: "La sécurité sans transparence n'est pas juste — elle est nuisible. Le système actuel échoue en matière de transparence, d'équité, d'efficacité et de surveillance.",
  },
  {
    src: "/events/can731-2026/photos/legoStyle.png",
    alt: "Waiting without a timeline should not become a life sentence — some applicants have spent 30, 40, 50, even 60+ months in security screening.",
    captionEn: "Waiting without a timeline should not become a life sentence. Some applicants have been in security screening for 30, 40, 50, even 60+ months.",
    captionZh: "没有时间线的等待，不应该变成无期徒刑。有些申请人已经在安全审查中等待了30、40、50甚至60多个月。",
    captionFr: "Attendre sans échéancier ne devrait pas devenir une peine à perpétuité. Certains demandeurs attendent depuis 30, 40, 50, voire plus de 60 mois.",
  },
  {
    src: "/events/can731-2026/photos/LivesOnHold.jpg",
    alt: "Families waiting, lives on hold — transparency now. We ask for greater transparency, meaningful status updates, reasonable timelines, and accountability.",
    captionEn: "Families waiting. Lives on hold. Transparency now! We are healthcare workers, tradespeople, educators, students, and more — asking for transparency, meaningful updates, reasonable timelines, and accountability.",
    captionZh: "家庭在等待，生活被搁置。现在就要透明！我们是医护人员、技工、教育工作者、学生等——我们要求透明度、有意义的进展通报、合理时限与问责。",
    captionFr: "Des familles attendent. Des vies en suspens. De la transparence maintenant! Nous demandons transparence, mises à jour significatives, délais raisonnables et reddition de comptes.",
  },
  {
    src: "/events/can731-2026/photos/can731-poster-en.png",
    alt: "CAN731 campaign poster: Canada United — for fairness, for accountability, for all. Ottawa 313, Vancouver 501, Toronto 528 finished successfully; 731 across Canada is the final piece, coming July 31, 2026.",
    captionEn: "One nation. Countless stories. One goal. Complete the puzzle — spark the change.",
    captionZh: "一个国家，无数故事，一个目标。完成这片拼图，启动改变。",
    captionFr: "Une nation. D'innombrables histoires. Un seul objectif. Complétons le casse-tête — déclenchons le changement.",
  },
];
---

<BaseLayout title="CAN731 National Day of Action | Justice for Chinese PR Applicants" description="July 31, 2026 — a nationwide day of action across Canada calling for fair, transparent, and timely immigration security screening.">
  <section class="can-hero">
    <div class="can-hero-inner">
      <p class="can-kicker">
        <span class="lang-en">CAN731 · Nationwide</span>
        <span class="lang-zh">CAN731 · 全国</span>
        <span class="lang-fr">CAN731 · Partout au pays</span>
      </p>
      <h2>
        <span class="lang-en">Unite Canada — National Day of Action</span>
        <span class="lang-zh">团结加拿大！全国和平集会</span>
        <span class="lang-fr">Unissons le Canada — Journée d'action nationale</span>
      </h2>
      <p class="can-hero-copy">
        <span class="lang-en">For fairness. For accountability. For everyone. On July 31, 2026, Ottawa, Vancouver, Toronto, and cities across Canada will stand together — in person and online — to call for fair, transparent, and timely immigration security screening.</span>
        <span class="lang-zh">为了公平，为了问责，为了所有人。2026年7月31日，渥太华、温哥华、多伦多及全国各地将同步行动——线上线下同步进行——呼吁公平、透明、有明确时限的移民安全审查。</span>
        <span class="lang-fr">Pour l'équité. Pour la reddition de comptes. Pour tout le monde. Le 31 juillet 2026, Ottawa, Vancouver, Toronto et des villes partout au pays se mobiliseront ensemble — en personne et en ligne — pour réclamer des vérifications de sécurité en immigration équitables, transparentes et assorties de délais clairs.</span>
      </p>
    </div>
  </section>

  <section class="can-event">
    <div class="container">
      <div class="can-summary-grid">
        <div class="can-summary-card">
          <span class="can-summary-label">
            <span class="lang-en">Date</span>
            <span class="lang-zh">日期</span>
            <span class="lang-fr">Date</span>
          </span>
          <strong>
            <span class="lang-en">Friday, July 31, 2026</span>
            <span class="lang-zh">2026年7月31日 周五</span>
            <span class="lang-fr">Vendredi 31 juillet 2026</span>
          </strong>
        </div>
        <div class="can-summary-card">
          <span class="can-summary-label">
            <span class="lang-en">Where</span>
            <span class="lang-zh">地点</span>
            <span class="lang-fr">Lieu</span>
          </span>
          <strong>
            <span class="lang-en">Nationwide — online &amp; in person</span>
            <span class="lang-zh">全国各地 · 线上及线下同步进行</span>
            <span class="lang-fr">Partout au pays — en ligne et en personne</span>
          </strong>
        </div>
        <div class="can-summary-card">
          <span class="can-summary-label">
            <span class="lang-en">We Demand</span>
            <span class="lang-zh">我们要求</span>
            <span class="lang-fr">Nos revendications</span>
          </span>
          <strong>
            <span class="lang-en">Timelines · Accountability · Fairness · Transparency</span>
            <span class="lang-zh">时间框架 · 问责制 · 公平公正 · 透明度</span>
            <span class="lang-fr">Délais · Reddition de comptes · Équité · Transparence</span>
          </strong>
        </div>
      </div>

      <section class="can-poster">
        <div class="can-poster-image">
          <img
            src="/events/can731-2026/photos/dadTraped.jpg"
            alt="A handmade family scrapbook: Grandma fell. Time is running out. Dad trapped — save us."
            loading="lazy"
          />
        </div>
        <p class="can-poster-caption">
          <span class="lang-en">A handmade family scrapbook: "Grandma fell." "Time is running out." "Dad trapped — save us." Real stories of families torn apart while security screening drags on.</span>
          <span class="lang-zh">一本手工制作的家庭剪贴簿："奶奶摔倒了"、"时间不等人"、"爸爸被困住了——救救我们"。安全审查无限期拖延，撕裂的是真实的家庭。</span>
          <span class="lang-fr">Un album familial fait main : « Grand-maman est tombée », « Le temps presse », « Papa est piégé — sauvez-nous ». Des histoires vraies de familles déchirées par des vérifications de sécurité interminables.</span>
        </p>
      </section>

      <div class="can-section-heading">
        <p class="can-kicker can-kicker-dark">
          <span class="lang-en">Campaign Materials</span>
          <span class="lang-zh">宣传物料</span>
          <span class="lang-fr">Documents de campagne</span>
        </p>
        <h2>
          <span class="lang-en">Why fair screening matters</span>
          <span class="lang-zh">为什么公平审查如此重要</span>
          <span class="lang-fr">Pourquoi des vérifications équitables sont importantes</span>
        </h2>
      </div>

      <div class="can-materials-grid">
        {campaignMaterials.map((item) => (
          <a class="can-material-card" href={item.src} target="_blank" rel="noopener noreferrer">
            <span class="can-material-image">
              <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
            </span>
            <span class="can-material-caption">
              <span class="lang-en">{item.captionEn}</span>
              <span class="lang-zh">{item.captionZh}</span>
              <span class="lang-fr">{item.captionFr}</span>
            </span>
          </a>
        ))}
      </div>

      <div class="can-section-heading">
        <p class="can-kicker can-kicker-dark">
          <span class="lang-en">The Journey So Far</span>
          <span class="lang-zh">此前的行动</span>
          <span class="lang-fr">Le parcours jusqu'ici</span>
        </p>
        <h2>
          <span class="lang-en">Three cities, three peaceful actions — already complete</span>
          <span class="lang-zh">三座城市，三场和平行动——均已圆满完成</span>
          <span class="lang-fr">Trois villes, trois actions pacifiques — déjà accomplies</span>
        </h2>
      </div>

      <div class="can-past-grid">
        {pastActions.map((action) => (
          <a href={action.href} class="can-past-card">
            <span class="can-past-check" aria-hidden="true">✓</span>
            <span class="can-past-count">{action.count}</span>
            <span class="can-past-code">{action.code}</span>
            <span class="can-past-city">
              <span class="lang-en">{action.city}</span>
              <span class="lang-zh">{action.cityZh}</span>
              <span class="lang-fr">{action.city}</span>
            </span>
            <span class="can-past-venue">
              <span class="lang-en">{action.venue}</span>
              <span class="lang-zh">{action.venueZh}</span>
              <span class="lang-fr">{action.venue}</span>
            </span>
            <span class="can-past-date">
              <span class="lang-en">{action.date}</span>
              <span class="lang-zh">{action.dateZh}</span>
              <span class="lang-fr">{action.date}</span>
            </span>
          </a>
        ))}
      </div>

      <div class="can-section-heading">
        <p class="can-kicker can-kicker-dark">
          <span class="lang-en">CAN731 · The Final Piece</span>
          <span class="lang-zh">CAN731 · 最后一块拼图</span>
          <span class="lang-fr">CAN731 · La dernière pièce</span>
        </p>
        <h2>
          <span class="lang-en">One day. One voice. One Canada — coast to coast.</span>
          <span class="lang-zh">同一天，同一个声音，同一个加拿大。</span>
          <span class="lang-fr">Un jour. Une voix. Un Canada — d'un océan à l'autre.</span>
        </h2>
      </div>

      <div class="can-qr-card">
        <span class="can-qr-label">
          <span class="lang-en">Scan to join a WeChat group</span>
          <span class="lang-zh">扫码加入微信群</span>
          <span class="lang-fr">Scannez pour rejoindre un groupe WeChat</span>
        </span>
        <div class="can-qr-grid">
          <div class="can-qr-item">
            <img src="/events/can731-2026/qrcodes/toronto-wechat.png" alt="Toronto WeChat group QR code" width="140" height="140" loading="lazy" />
            <span class="can-qr-city">
              <span class="lang-en">Toronto</span>
              <span class="lang-zh">多伦多</span>
              <span class="lang-fr">Toronto</span>
            </span>
            <span class="can-qr-group">731多伦多集会</span>
          </div>
          <div class="can-qr-item">
            <img src="/events/can731-2026/qrcodes/vancouver-wechat.png" alt="Vancouver WeChat group QR code" width="140" height="140" loading="lazy" />
            <span class="can-qr-city">
              <span class="lang-en">Vancouver</span>
              <span class="lang-zh">温哥华</span>
              <span class="lang-fr">Vancouver</span>
            </span>
            <span class="can-qr-group">260731-VAN温哥华群</span>
          </div>
        </div>
        <p class="can-qr-note">
          <span class="lang-en">More city groups will be announced as July 31 approaches. Email us at we@chinese-pr-delay.ca to connect.</span>
          <span class="lang-zh">更多城市群将在 7月31日 临近时陆续公布。欢迎邮件联系 we@chinese-pr-delay.ca。</span>
          <span class="lang-fr">D'autres groupes locaux seront annoncés à l'approche du 31 juillet. Écrivez-nous à we@chinese-pr-delay.ca pour vous joindre.</span>
        </p>
      </div>

      <div class="can-section-heading">
        <p class="can-kicker can-kicker-dark">
          <span class="lang-en">By the Numbers</span>
          <span class="lang-zh">数据说明</span>
          <span class="lang-fr">En chiffres</span>
        </p>
        <h2>
          <span class="lang-en">The gap between policy and reality</span>
          <span class="lang-zh">政策与现实之间的差距</span>
          <span class="lang-fr">L'écart entre la politique et la réalité</span>
        </h2>
      </div>

      <div class="can-stats-grid">
        <div class="can-stat-card can-stat-card-highlight">
          <strong>64.8 months</strong>
          <span>Current estimated CBSA wait time for PR security screening — roughly 18× longer than the published 110-day standard.</span>
        </div>
        <div class="can-stat-card">
          <strong>110 days</strong>
          <span>CBSA's own published service standard for PR security screening.</span>
        </div>
        <div class="can-stat-card">
          <strong>23,000+</strong>
          <span>Applications currently stalled in security screening.</span>
        </div>
        <div class="can-stat-card">
          <strong>535,300+</strong>
          <span>Immigration applications in the national backlog.</span>
        </div>
        <div class="can-stat-card">
          <strong>180 days – 12 months</strong>
          <span>IRCC's own published service standards for Economic Immigration (180 days – 11 months) and Family Sponsorship (12 months).</span>
        </div>
      </div>
      <p class="can-source-note">
        Source: CBSA and IRCC published service standards; figures compiled from public data as of 2026. ·
        <a href="/events/can731-2026/reference-information.pdf" target="_blank" rel="noopener noreferrer">Download the full reference sheet (PDF)</a>
      </p>

      <div class="can-info-grid">
        <section class="can-info-panel">
          <h2>
            <span class="lang-en">House of Commons Petitions</span>
            <span class="lang-zh">众议院请愿</span>
            <span class="lang-fr">Pétitions à la Chambre des communes</span>
          </h2>
          <ul>
            <li>
              <strong>Petition e-7259</strong> — 13,507 signatures. Calls for timelines, regular status updates, independent oversight, and greater accountability for prolonged immigration security screening delays. Presented in Parliament on May 25, 2026.
            </li>
            <li>
              <strong>Petition e-7341</strong> — 4,484 signatures. Calls for a parliamentary review of immigration security screening to examine capacity, accountability, risk-based triage, and independent oversight.
            </li>
          </ul>
        </section>

        <section class="can-info-panel">
          <h2>
            <span class="lang-en">Briefing Notes Submitted to CIMM</span>
            <span class="lang-zh">提交国会移民委员会的简报</span>
            <span class="lang-fr">Notes d'information soumises au CIMM</span>
          </h2>
          <p class="can-panel-subtitle">Formally submitted to the House of Commons Standing Committee on Citizenship and Immigration (CIMM) for consideration:</p>
          <ul>
            <li>CBSA Security Screening Backlog Collapse: Quantitative Evidence and Disproportionate Impact on Inland and Chinese PR Applicants</li>
            <li>Prolonged Inland PR Security Screening: Transparency, Timelines, and Public Confidence</li>
            <li>Security Screening Delays as a Structural Weakness in Canada's Immigration System</li>
          </ul>
        </section>
      </div>

      <div class="can-info-grid">
        <section class="can-info-panel">
          <h2>
            <span class="lang-en">In the News</span>
            <span class="lang-zh">媒体报道</span>
            <span class="lang-fr">Dans les médias</span>
          </h2>
          <div class="can-news-group">
            <h3>March 13, 2026 — Ottawa</h3>
            <ul>
              <li>News conference: "Group calls for transparency and reasonable timelines in immigration processing"</li>
              <li>Parliament Hill Press Conference News Release</li>
              <li>OMNI News: "Stuck Forever": Chinese Immigrants Protest IRCC Delays</li>
              <li>Public support from Senator Yuen Pau Woo</li>
            </ul>
          </div>
          <div class="can-news-group">
            <h3>May 1, 2026 — Vancouver</h3>
            <ul>
              <li>CityNews: Permanent Residence Applicants Protest Long Wait Times from IRCC</li>
              <li>CBC / Radio-Canada: Permanent residency: a desperate wait</li>
              <li>OMNI News: About 200 applicants protested at the Department of Immigration, urging faster handling of backlog cases</li>
            </ul>
          </div>
          <div class="can-news-group">
            <h3>May 28, 2026 — Mississauga</h3>
            <ul>
              <li>OMNI News: Mississauga Protest Against Indefinite Immigration Security Screening</li>
              <li>Voices and Bridges: Protest Held in Mississauga by Individuals Affected by Security Screening Delays Across Canada</li>
              <li>Weber Immigration: Highlights from Mississauga Protest — "our hearts break for those who have been waiting years for decisions"</li>
              <li>FairChild TV: coverage of the protest outside the Federal Immigration Office in Mississauga, Ontario</li>
            </ul>
          </div>
        </section>

        <section class="can-info-panel">
          <h2>
            <span class="lang-en">Voices of Support</span>
            <span class="lang-zh">支持者的声音</span>
            <span class="lang-fr">Voix de soutien</span>
          </h2>
          <ul class="can-voices-list">
            {supportVoices.map((voice) => (
              <li>
                <a href={voice.href} target="_blank" rel="noopener noreferrer">
                  <strong>{voice.name}</strong>
                  <span>{voice.role}</span>
                </a>
              </li>
            ))}
          </ul>
          <p class="can-panel-subtitle can-panel-subtitle-tight">Industry commentary:</p>
          <ul>
            <li>Institute for Research on Public Policy: "Opaque immigration screening threatens Canada's global talent strategy"</li>
            <li>"The Hidden Domino Effect of Immigration Security Screening Delays in Canada"</li>
          </ul>
        </section>
      </div>

      <div class="can-cta">
        <h2>
          <span class="lang-en">Join the CAN731 National Day of Action</span>
          <span class="lang-zh">加入 CAN731 全国和平集会</span>
          <span class="lang-fr">Participez à la journée d'action nationale CAN731</span>
        </h2>
        <p>
          <span class="lang-en">Whether you can join us in Ottawa, Vancouver, Toronto, another city, or online, your voice completes the puzzle. Connect with organizers to stay updated as details are confirmed.</span>
          <span class="lang-zh">无论你能在渥太华、温哥华、多伦多、其他城市还是线上参与，你的声音都是这块拼图的一部分。请联系组织者以获取最新详情。</span>
          <span class="lang-fr">Que vous puissiez vous joindre à nous à Ottawa, à Vancouver, à Toronto, dans une autre ville ou en ligne, votre voix complète le casse-tête. Communiquez avec les organisateurs pour rester informé.</span>
        </p>
        <a href="/join#join" class="can-cta-link">
          <span class="lang-en">Contact organizers</span>
          <span class="lang-zh">联系组织者</span>
          <span class="lang-fr">Contacter les organisateurs</span>
        </a>
      </div>

      <section class="can-social">
        <div class="can-social-header">
          <p class="can-kicker can-kicker-dark">
            <span class="lang-en">Social Media</span>
            <span class="lang-zh">社交媒体</span>
            <span class="lang-fr">Réseaux sociaux</span>
          </p>
          <h2>
            <span class="lang-en">Help amplify the campaign online</span>
            <span class="lang-zh">请在线上帮助扩大行动声量</span>
            <span class="lang-fr">Aidez à amplifier la campagne en ligne</span>
          </h2>
          <p>
            <span class="lang-en">Please like, comment, subscribe, and share so more applicants and allies can find CAN731.</span>
            <span class="lang-zh">请大家点赞、评论、订阅并转发，让更多申请人和支持者看到 CAN731。</span>
            <span class="lang-fr">Aimez, commentez, abonnez-vous et partagez afin que davantage de demandeurs et d'alliés découvrent CAN731.</span>
          </p>
        </div>

        <div class="can-social-grid">
          <a href="https://x.com/VoicesFairCheck" class="can-social-card" target="_blank" rel="noopener noreferrer">
            <span class="can-social-image">
              <img src="/images/social-x.svg" alt="X logo" width="56" height="56" loading="lazy" />
            </span>
            <span class="can-social-content">
              <strong>X</strong>
              <span>@VoicesFairCheck</span>
            </span>
          </a>

          <a href="https://www.youtube.com/@VoicesforFairScreening" class="can-social-card can-social-card-youtube" target="_blank" rel="noopener noreferrer">
            <span class="can-social-image">
              <img src="/images/social-youtube.svg" alt="YouTube logo" width="56" height="56" loading="lazy" />
            </span>
            <span class="can-social-content">
              <strong>YouTube</strong>
              <span>@VoicesforFairScreening</span>
            </span>
          </a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .can-hero {
    background:
      linear-gradient(125deg, rgba(15, 23, 42, 0.96), rgba(30, 58, 138, 0.9) 52%, rgba(185, 28, 28, 0.78)),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      #1e3a8a;
    background-size: auto, 72px 72px, auto;
    color: #ffffff;
    padding: 7rem 1.5rem 5.5rem;
    text-align: center;
  }

  .can-hero-inner {
    max-width: 880px;
    margin: 0 auto;
  }

  .can-kicker {
