---
// "Speak Out" section — Niemöller quote + call to action
import { speakOut } from '../i18n/strings';
---

<section class="speak-out-section">
    <div class="container">
        <blockquote class="speak-out-quote">
            <p><span class="lang-en">{speakOut.line1.en}</span><span class="lang-zh">{speakOut.line1.zh}</span><span class="lang-fr">{speakOut.line1.fr}</span></p>
            <p><span class="lang-en">{speakOut.line2.en}</span><span class="lang-zh">{speakOut.line2.zh}</span><span class="lang-fr">{speakOut.line2.fr}</span></p>
            <p><span class="lang-en">{speakOut.line3.en}</span><span class="lang-zh">{speakOut.line3.zh}</span><span class="lang-fr">{speakOut.line3.fr}</span></p>
            <p><span class="lang-en">{speakOut.line4.en}</span><span class="lang-zh">{speakOut.line4.zh}</span><span class="lang-fr">{speakOut.line4.fr}</span></p>
            <p><span class="lang-en">{speakOut.line5.en}</span><span class="lang-zh">{speakOut.line5.zh}</span><span class="lang-fr">{speakOut.line5.fr}</span></p>
            <footer class="speak-out-attribution">
                <span class="lang-en">{speakOut.attribution.en}</span>
                <span class="lang-zh">{speakOut.attribution.zh}</span>
                <span class="lang-fr">{speakOut.attribution.fr}</span>
            </footer>
        </blockquote>

        <div class="speak-out-callout">
            <p class="speak-out-question">
                <span class="lang-en">{speakOut.question.en}</span>
                <span class="lang-zh">{speakOut.question.zh}</span>
                <span class="lang-fr">{speakOut.question.fr}</span>
            </p>
            <p class="speak-out-answer">
                <span class="lang-en">{speakOut.answer.en}</span>
                <span class="lang-zh">{speakOut.answer.zh}</span>
                <span class="lang-fr">{speakOut.answer.fr}</span>
            </p>
        </div>
    </div>
</section>

<style>
    .speak-out-section {
        background: var(--primary-dark);
        padding: 4rem 1.5rem;
    }

    .speak-out-quote {
        max-width: 720px;
        margin: 0 auto;
        padding: 0;
        border: none;
        text-align: center;
    }

    .speak-out-quote p {
        margin: 0 0 0.6rem;
        font-family: var(--font-heading);
        font-style: italic;
        font-size: clamp(1.05rem, 2.4vw, 1.35rem);
        line-height: 1.5;
        color: rgba(255, 255, 255, 0.94);
    }

    .speak-out-attribution {
        margin-top: 1.1rem;
        font-family: var(--font-body);
        font-style: normal;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        color: var(--accent-bright);
    }

    .speak-out-callout {
        max-width: 720px;
        margin: 2.5rem auto 0;
        padding: 1.5rem 1.75rem;
        background: rgba(255, 255, 255, 0.06);
        border-left: 4px solid var(--red);
        border-radius: 4px;
    }

    .speak-out-question {
        margin: 0 0 0.5rem;
        font-weight: 800;
        font-size: clamp(1.1rem, 2.6vw, 1.4rem);
        color: #ffffff;
    }

    .speak-out-answer {
        margin: 0;
        font-size: 1rem;
        line-height: 1.65;
        color: rgba(255, 255, 255, 0.88);
    }

    @media (max-width: 640px) {
        .speak-out-section {
            padding: 3rem 1.25rem;
        }

        .speak-out-callout {
            padding: 1.25rem 1.25rem;
        }
    }
</style>
