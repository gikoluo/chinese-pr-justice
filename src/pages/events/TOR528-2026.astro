---
import BaseLayout from "../../layouts/BaseLayout.astro";

const tor528Photos = [
  "tor528-014.jpg",
  "tor528-017.jpg",
  "tor528-018.jpg",
  "tor528-019.jpg",
  "tor528-020.jpg",
  "tor528-021.jpg",
  "tor528-023.jpg",
  "tor528-024.jpg",
  "tor528-025.jpg",
  "tor528-026.jpg",
  "tor528-027.jpg",
  "tor528-028.jpg",
  "tor528-029.jpg",
  "tor528-030.jpg",
  "tor528-031.jpg",
  "tor528-032.jpg",
  "tor528-033.jpg",
  "tor528-034.jpg",
  "tor528-035.jpg",
  "tor528-036.jpg",
  "tor528-037.jpg",
  "tor528-038.jpg",
  "tor528-039.jpg",
  "tor528-040.jpg",
  "tor528-041.jpg",
  "tor528-042.jpg",
  "tor528-043.jpg",
  "tor528-044.jpg",
];
---

<BaseLayout title="Mississauga May 28 Peaceful Rally | Justice for Chinese PR Applicants">
  <section class="tor-hero">
    <div class="tor-hero-inner">
      <p class="tor-kicker">
        <span class="lang-en">TOR528 · Mississauga</span>
        <span class="lang-zh">TOR528 · 密西沙加</span>
        <span class="lang-fr">TOR528 · Mississauga</span>
      </p>
      <h2>
        <span class="lang-en">Mississauga May 28 Peaceful Rally</span>
        <span class="lang-zh">密西沙加 5月28日和平集会</span>
        <span class="lang-fr">Rassemblement pacifique du 28 mai à Mississauga</span>
      </h2>
      <p class="tor-hero-copy">
        <span class="lang-en">A peaceful public action calling for fair, transparent, and clear timeline for PR security screening.</span>
        <span class="lang-zh">一次和平的公共区域行动，呼吁永久居民安调审理公平、透明，并给出明确时间线。</span>
        <span class="lang-fr">Une action publique pacifique pour demander un processus équitable, transparent et un calendrier clair pour les vérifications de sécurité des demandes de RP.</span>
      </p>
    </div>
  </section>

  <section class="tor-event">
    <div class="container">
      <div class="tor-alert">
        <strong>
          <span class="lang-en">Check-in required</span>
          <span class="lang-zh">需要签到</span>
          <span class="lang-fr">Présence à confirmer sur place</span>
        </strong>
        <span>
          <span class="lang-en">Please check in with organizers when you arrive.</span>
          <span class="lang-zh">到场后请向组织者签到。</span>
          <span class="lang-fr">Veuillez vous présenter aux organisateurs à votre arrivée.</span>
        </span>
      </div>

      <div class="tor-summary-grid">
        <div class="tor-summary-card">
          <span class="tor-summary-label">
            <span class="lang-en">Date</span>
            <span class="lang-zh">日期</span>
            <span class="lang-fr">Date</span>
          </span>
          <strong>
            <span class="lang-en">Thursday, May 28, 2026</span>
            <span class="lang-zh">2026年5月28日 周四</span>
            <span class="lang-fr">Jeudi 28 mai 2026</span>
          </strong>
        </div>
        <div class="tor-summary-card">
          <span class="tor-summary-label">
            <span class="lang-en">Time</span>
            <span class="lang-zh">时间</span>
            <span class="lang-fr">Heure</span>
          </span>
          <strong>
            <span class="lang-en">7:30 AM – 11:30 AM</span>
            <span class="lang-zh">上午7:30 – 上午11:30</span>
            <span class="lang-fr">7 h 30 – 11 h 30</span>
          </strong>
        </div>
        <div class="tor-summary-card">
          <span class="tor-summary-label">
            <span class="lang-en">Format</span>
            <span class="lang-zh">形式</span>
            <span class="lang-fr">Format</span>
          </span>
          <strong>
            <span class="lang-en">Two public-area stops, speeches & chants</span>
            <span class="lang-zh">两个公共区域点位、发言与口号</span>
            <span class="lang-fr">Deux lieux publics, discours et slogans</span>
          </strong>
        </div>
      </div>

      <div class="tor-section-heading">
        <p class="tor-kicker tor-kicker-dark">
          <span class="lang-en">Action Route</span>
          <span class="lang-zh">行动路线</span>
          <span class="lang-fr">Itinéraire</span>
        </p>
        <h2>
          <span class="lang-en">From the summit hotel area to the Mississauga IRCC office</span>
          <span class="lang-zh">从峰会酒店外公共区域到密西沙加 IRCC 办公室</span>
          <span class="lang-fr">De l’hôtel du sommet au bureau d’IRCC à Mississauga</span>
        </h2>
      </div>

      <div class="tor-route-grid">
        <article class="tor-stop-card">
          <div class="tor-stop-time">Phase 1</div>
          <h3>
            <span class="lang-en">Hilton Mississauga/Meadowvale</span>
            <span class="lang-zh">Hilton Mississauga/Meadowvale</span>
            <span class="lang-fr">Hilton Mississauga/Meadowvale</span>
          </h3>
          <p class="tor-stop-lines">
            <span>
              <span class="lang-en">7:30 AM — 10:00 AM</span>
              <span class="lang-zh">上午7:30 — 上午10:00</span>
              <span class="lang-fr">7 h 30 — 10 h 00</span>
            </span>
            <span>
              <span class="lang-en">Public sidewalk & boulevard area (Argentia Rd side)</span>
              <span class="lang-zh">公共人行道与路侧绿化带区域（Argentia Rd 一侧）</span>
              <span class="lang-fr">Trottoir public et boulevard (côté Argentia Rd)</span>
            </span>
            <span>6750 Mississauga Rd, Mississauga, ON L5N 2L3</span>
          </p>
        </article>

        <article class="tor-stop-card tor-stop-card-red">
          <div class="tor-stop-time">Phase 2</div>
          <h3>
            <span class="lang-en">Citizenship and Immigration Canada Office</span>
            <span class="lang-zh">Citizenship and Immigration Canada Office</span>
            <span class="lang-fr">Citizenship and Immigration Canada Office</span>
          </h3>
          <p class="tor-stop-lines">
            <span>
              <span class="lang-en">10:45 AM — 11:30 AM</span>
              <span class="lang-zh">上午10:45 — 上午11:30</span>
              <span class="lang-fr">10 h 45 — 11 h 30</span>
            </span>
            <span>
              <span class="lang-en">Public sidewalk & boulevard area (Glen Erin Dr side)</span>
              <span class="lang-zh">公共人行道与路侧绿化带区域（Glen Erin Dr 一侧）</span>
              <span class="lang-fr">Trottoir public et boulevard (côté Glen Erin Dr)</span>
            </span>
            <span>3085 Glen Erin Dr, Mississauga, ON L5L 1J3</span>
          </p>
        </article>
      </div>

      <div class="tor-map-card">
        <div class="tor-map-header">
          <h2>
            <span class="lang-en">Route Map</span>
            <span class="lang-zh">路线图</span>
            <span class="lang-fr">Carte de l’itinéraire</span>
          </h2>
          <a
            href="https://www.google.com/maps/dir/?api=1&origin=6750%20Mississauga%20Rd%2C%20Mississauga%2C%20ON%20L5N%202L3&destination=3085%20Glen%20Erin%20Dr%2C%20Mississauga%2C%20ON%20L5L%201J3"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="lang-en">Open in Google Maps</span>
            <span class="lang-zh">在 Google 地图中打开</span>
            <span class="lang-fr">Ouvrir dans Google Maps</span>
          </a>
        </div>
        <iframe
          title="TOR528 route map from 6750 Mississauga Road to 3085 Glen Erin Drive"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?output=embed&saddr=6750%20Mississauga%20Rd%2C%20Mississauga%2C%20ON%20L5N%202L3&daddr=3085%20Glen%20Erin%20Dr%2C%20Mississauga%2C%20ON%20L5L%201J3"
        ></iframe>
      </div>

      <div class="tor-info-grid">
        <section class="tor-info-panel">
          <h2>
            <span class="lang-en">Schedule</span>
            <span class="lang-zh">日程</span>
            <span class="lang-fr">Horaire</span>
          </h2>
          <div class="tor-phase-grid">
            <div class="tor-phase-card">
              <h3>Phase 1</h3>
              <p class="tor-phase-location">
                <span class="lang-en">Public space outside hotel (Argentia Rd side)</span>
                <span class="lang-zh">酒店外公共区域（Argentia Rd 一侧）</span>
                <span class="lang-fr">Espace public devant l’hôtel (côté Argentia Rd)</span>
              </p>
              <div class="tor-schedule-list">
                <div class="tor-schedule-row">
                  <span>7:00</span>
                  <p>
                    <span class="lang-en">Core team arrives early to set up</span>
                    <span class="lang-zh">核心团队提前到场完成布置</span>
                    <span class="lang-fr">L’équipe principale arrive tôt pour l’installation</span>
                  </p>
                </div>
                <div class="tor-schedule-row">
                  <span>7:30</span>
                  <p>
                    <span class="lang-en">Gather, sign up and distribute signs</span>
                    <span class="lang-zh">集合、签到并发放标语牌</span>
                    <span class="lang-fr">Rassemblement, inscription et distribution des pancartes</span>
                  </p>
                </div>
                <div class="tor-schedule-row">
                  <span>8:00</span>
                  <p>
                    <span class="lang-en">Opening remarks, lead chants</span>
                    <span class="lang-zh">开场发言并领喊口号</span>
                    <span class="lang-fr">Remarques d’ouverture et slogans menés par l’équipe</span>
                  </p>
                </div>
                <div class="tor-schedule-row">
                  <span>8:15–9:45</span>
                  <p>
                    <span class="lang-en">Speakers & chants</span>
                    <span class="lang-zh">发言与口号</span>
                    <span class="lang-fr">Interventions et slogans</span>
                  </p>
                </div>
                <div class="tor-schedule-row">
                  <span>9:50</span>
                  <p>
                    <span class="lang-en">Group photo</span>
                    <span class="lang-zh">集体合影</span>
                    <span class="lang-fr">Photo de groupe</span>
                  </p>
                </div>
                <div class="tor-schedule-row">
                  <span>10:00</span>
                  <p>
                    <span class="lang-en">Assemble for departure</span>
                    <span class="lang-zh">集合准备出发</span>
                    <span class="lang-fr">Rassemblement avant le départ</span>
                  </p>
                </div>
              </div>
              <p class="tor-travel-note">
                <span class="lang-en">Travel: Drive or public transit → IRCC</span>
                <span class="lang-zh">转场：自驾或公共交通 → IRCC</span>
                <span class="lang-fr">Déplacement : voiture ou transport en commun → IRCC</span>
              </p>
            </div>

            <div class="tor-phase-card">
              <h3>Phase 2</h3>
              <p class="tor-phase-location">
                <span class="lang-en">Public space outside IRCC Office (Glen Erin Dr side)</span>
                <span class="lang-zh">IRCC 办公室外公共区域（Glen Erin Dr 一侧）</span>
                <span class="lang-fr">Espace public devant le bureau d’IRCC (côté Glen Erin Dr)</span>
              </p>
              <div class="tor-schedule-list">
                <div class="tor-schedule-row">
                  <span>10:45</span>
                  <p>
                    <span class="lang-en">Arrive at 3085 Glen Erin Dr</span>
                    <span class="lang-zh">抵达 3085 Glen Erin Dr</span>
                    <span class="lang-fr">Arrivée au 3085 Glen Erin Dr</span>
                  </p>
                </div>
                <div class="tor-schedule-row">
                  <span>10:45</span>
                  <p>
                    <span class="lang-en">Assemble, speakers & chants</span>
                    <span class="lang-zh">集合、发言与口号</span>
                    <span class="lang-fr">Rassemblement, interventions et slogans</span>
                  </p>
                </div>
                <div class="tor-schedule-row">
                  <span>11:15</span>
                  <p>
                    <span class="lang-en">Closing remarks</span>
                    <span class="lang-zh">结束发言</span>
                    <span class="lang-fr">Remarques de clôture</span>
                  </p>
                </div>
                <div class="tor-schedule-row">
                  <span>11:20</span>
                  <p>
                    <span class="lang-en">Group photo</span>
                    <span class="lang-zh">集体合影</span>
                    <span class="lang-fr">Photo de groupe</span>
                  </p>
                </div>
                <div class="tor-schedule-row">
                  <span>11:30</span>
                  <p>
                    <span class="lang-en">Orderly dispersal</span>
                    <span class="lang-zh">有序散场</span>
                    <span class="lang-fr">Dispersion ordonnée</span>
                  </p>
                </div>
              </div>
            </div>
          </div>
          <p class="tor-note">
            <span class="lang-en">Schedule & locations subject to change depending on the on-site situation. Follow our WeChat group messages.</span>
            <span class="lang-zh">日程与地点可能根据现场情况调整，请关注微信群消息。</span>
            <span class="lang-fr">L’horaire et les lieux peuvent changer selon la situation sur place. Suivez les messages de notre groupe WeChat.</span>
          </p>
        </section>

        <section class="tor-info-panel">
          <h2>
            <span class="lang-en">Participant Notes</span>
            <span class="lang-zh">参与者须知</span>
            <span class="lang-fr">Notes aux participants</span>
          </h2>
          <ul>
            <li>
              <span class="lang-en">Stay in public areas and follow organizer guidance.</span>
              <span class="lang-zh">请停留在公共区域，并听从组织者现场指引。</span>
              <span class="lang-fr">Restez dans les espaces publics et suivez les consignes des organisateurs.</span>
            </li>
            <li>
              <span class="lang-en">Keep signs clear, respectful, and focused on PR processing fairness.</span>
              <span class="lang-zh">标语请保持清晰、克制，并聚焦 PR 审理公平。</span>
              <span class="lang-fr">Gardez les affiches claires, respectueuses et centrées sur l’équité du traitement des demandes de RP.</span>
            </li>
            <li>
              <span class="lang-en">Bring water, weather-appropriate clothing, and portable phone power.</span>
              <span class="lang-zh">请携带饮水、适合天气的衣物和手机移动电源。</span>
              <span class="lang-fr">Apportez de l’eau, des vêtements adaptés à la météo et une batterie externe.</span>
            </li>
            <li>
              <span class="lang-en">Do not block entrances, roads, sidewalks, or emergency access.</span>
              <span class="lang-zh">不要阻挡入口、道路、人行道或紧急通道。</span>
              <span class="lang-fr">Ne bloquez pas les entrées, les routes, les trottoirs ou les accès d’urgence.</span>
            </li>
          </ul>
        </section>
      </div>

      <div class="tor-cta">
        <h2>
          <span class="lang-en">Join the TOR528 action</span>
          <span class="lang-zh">加入 TOR528 行动</span>
          <span class="lang-fr">Participez à l’action TOR528</span>
        </h2>
        <p>
          <span class="lang-en">If you plan to attend, please connect with organizers so we can coordinate check-in, materials, and location updates.</span>
          <span class="lang-zh">如果你计划参加，请先联系组织者，方便协调签到、物料和地点更新。</span>
          <span class="lang-fr">Si vous prévoyez participer, communiquez avec les organisateurs afin de coordonner la présence, le matériel et les mises à jour de lieu.</span>
        </p>
        <a href="/join" class="tor-cta-link">
          <span class="lang-en">Contact organizers</span>
          <span class="lang-zh">联系组织者</span>
          <span class="lang-fr">Contacter les organisateurs</span>
        </a>
      </div>

      <section class="tor-social">
        <div class="tor-social-header">
          <p class="tor-kicker tor-kicker-dark">
            <span class="lang-en">Social Media</span>
            <span class="lang-zh">社交媒体</span>
            <span class="lang-fr">Réseaux sociaux</span>
          </p>
          <h2>
            <span class="lang-en">Help amplify the campaign online</span>
            <span class="lang-zh">请在线上帮助扩大行动声量</span>
            <span class="lang-fr">Aidez à amplifier la campagne en ligne</span>
          </h2>
          <p>
            <span class="lang-en">Please like, comment, subscribe, and share so more applicants and allies can find the action.</span>
            <span class="lang-zh">请大家点赞、评论、订阅并转发，让更多申请人和支持者看到这次行动。</span>
            <span class="lang-fr">Aimez, commentez, abonnez-vous et partagez afin que davantage de demandeurs et d’alliés découvrent l’action.</span>
          </p>
        </div>

        <div class="tor-social-grid">
          <a href="https://x.com/voicesfaircheck?s=21" class="tor-social-card" target="_blank" rel="noopener noreferrer">
            <span class="tor-social-image">
              <img src="/images/social-x.svg" alt="X logo" width="56" height="56" loading="lazy" />
            </span>
            <span class="tor-social-content">
              <strong>X</strong>
              <span>@voicesfaircheck</span>
            </span>
          </a>

          <a href="https://youtube.com/@voicesforfairscreening?si=Rn4hZK2CSdTFDCHT" class="tor-social-card tor-social-card-youtube" target="_blank" rel="noopener noreferrer">
            <span class="tor-social-image">
              <img src="/images/social-youtube.svg" alt="YouTube logo" width="56" height="56" loading="lazy" />
            </span>
            <span class="tor-social-content">
              <strong>YouTube</strong>
              <span>@voicesforfairscreening</span>
            </span>
          </a>
        </div>
      </section>

      <section class="tor-gallery">
        <div class="tor-gallery-header">
          <p class="tor-kicker tor-gallery-kicker">
            <span class="lang-en">Event Photos</span>
            <span class="lang-zh">活动照片</span>
            <span class="lang-fr">Photos de l’événement</span>
          </p>
          <h2>
            <span class="lang-en">Scenes from the May 28 rally</span>
            <span class="lang-zh">5月28日集会现场</span>
            <span class="lang-fr">Moments du rassemblement du 28 mai</span>
          </h2>
          <p>
            <span class="lang-en">Selected photos from the TOR528 Mississauga peaceful rally.</span>
            <span class="lang-zh">TOR528 密西沙加和平集会的部分现场照片。</span>
            <span class="lang-fr">Sélection de photos du rassemblement pacifique TOR528 à Mississauga.</span>
          </p>
        </div>

        <div class="tor-gallery-grid">
          {tor528Photos.map((file, index) => (
            <figure class="tor-gallery-card">
              <img
                src={`/events/tor528-2026/photos/${file}`}
                alt={`TOR528 Mississauga peaceful rally photo ${index + 1}`}
                loading="lazy"
                decoding="async"
              />
            </figure>
          ))}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .tor-hero {
    background:
      linear-gradient(125deg, rgba(15, 23, 42, 0.96), rgba(30, 58, 138, 0.9) 52%, rgba(185, 28, 28, 0.78)),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      #1e3a8a;
    background-size: auto, 72px 72px, auto;
    color: #ffffff;
    padding: 7rem 1.5rem 5.5rem;
    text-align: center;
  }

  .tor-hero-inner {
    max-width: 880px;
    margin: 0 auto;
  }

  .tor-kicker {
    display: inline-flex;
    padding: 0.35rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    margin: 0 0 0.75rem;
    background: rgba(15, 23, 42, 0.35);
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .tor-kicker-dark {
    border-color: rgba(185, 28, 28, 0.28);
    background: rgba(185, 28, 28, 0.12);
    color: #fecaca;
  }

  .tor-hero h2 {
    margin: 0;
    font-family: var(--font-section-heading);
    color: #ffffff;
    font-size: clamp(2.2rem, 5vw, 4.2rem);
    line-height: 1.05;
  }

  .tor-hero-copy {
    max-width: 760px;
    margin: 1.1rem auto 0;
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .tor-event {
    background:
      linear-gradient(180deg, #0f172a 0, #1e3a8a 18rem, #334155 18rem, #0f172a 100%);
    padding: 3.5rem 0;
  }

  .tor-alert {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-left: 5px solid #b91c1c;
    background: rgba(15, 23, 42, 0.78);
    color: rgba(255, 255, 255, 0.88);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.24);
  }

  .tor-alert strong {
    color: #fecaca;
    white-space: nowrap;
  }

  .tor-summary-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .tor-summary-card,
  .tor-stop-card,
  .tor-info-panel,
  .tor-map-card,
  .tor-cta {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(248, 250, 252, 0.94);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
  }

  .tor-summary-card {
    position: relative;
    overflow: hidden;
    padding: 1.25rem;
    background: linear-gradient(145deg, #ffffff, #e0e7ff);
  }

  .tor-summary-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    background: #b91c1c;
  }

  .tor-summary-label {
    display: block;
    margin-bottom: 0.4rem;
    color: #64748b;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .tor-summary-card strong {
    color: #1e3a8a;
    font-size: 1rem;
    line-height: 1.45;
  }

  .tor-section-heading {
    max-width: 760px;
    margin: 3rem auto 1.3rem;
    text-align: center;
  }

  .tor-section-heading h2 {
    color: #ffffff;
  }

  .tor-event .tor-section-heading h2 {
