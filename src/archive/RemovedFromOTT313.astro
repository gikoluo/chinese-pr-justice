---
import { eventPage } from "../i18n/strings";
---

<!--
  Archived from src/pages/events/OTT313-2026.astro on 2026-05-21.
  This block was copied from an earlier VAN501-derived event section and is no
  longer rendered on the live OTT313 page. Keep it here for maintenance history.
-->
<section id="event" class="event-section">
  <div class="container">
    <div class="event-banner">
      <h3><span class="lang-en">{eventPage.bannerTitle.en}</span><span class="lang-zh">{eventPage.bannerTitle.zh}</span><span class="lang-fr">{eventPage.bannerTitle.fr}</span></h3>
      <p class="event-tagline">
        <span class="lang-en">{eventPage.bannerTagline.en}</span>
        <span class="lang-zh">{eventPage.bannerTagline.zh}</span>
        <span class="lang-fr">{eventPage.bannerTagline.fr}</span>
      </p>
    </div>

    <div class="event-livestream">
      <a
        href="https://bc-pr-delay.lol/#event"
        class="event-livestream-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="event-livestream-pill">
          <span class="event-livestream-dot" aria-hidden="true"></span>
          <span class="lang-en">View VAN501 recap and registration archive</span>
          <span class="lang-zh">查看 VAN501 回顾与报名存档</span>
          <span class="lang-fr">Voir le bilan VAN501 et l’archive d’inscription</span>
        </span>
      </a>
      <a href="/press-release" class="event-livestream-link event-press-release-link">
        <span class="event-livestream-pill">
          <span class="event-livestream-dot event-livestream-dot-muted" aria-hidden="true"></span>
          <span class="lang-en">{eventPage.pressReleasePill.en}</span>
          <span class="lang-zh">{eventPage.pressReleasePill.zh}</span>
          <span class="lang-fr">{eventPage.pressReleasePill.fr}</span>
        </span>
      </a>
      <a
        href="/events/Group%20Calls%20for%20Transparency%20and%20Timely%20Immigration%20Processing.pdf"
        class="event-livestream-link event-press-release-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="event-livestream-pill event-livestream-pill-pdf">
          <span class="event-livestream-dot event-livestream-dot-muted" aria-hidden="true"></span>
          <span class="lang-en">Download full press release (PDF)</span>
          <span class="lang-zh">下载完整通稿 PDF</span>
          <span class="lang-fr">Télécharger le communiqué complet (PDF)</span>
        </span>
      </a>
    </div>

    <div class="glance-card van501-alert">
      <h4>📌 Tentative — Schedule & locations subject to change</h4>
      <p>
        Follow our social media for updates as attendance numbers are confirmed.
      </p>
    </div>

    <div class="glance-card van501-alert">
      <h4>⚠️ Registration Notice for IRCC Building</h4>
      <p>
        To manage capacity, activities at the IRCC Vancouver office (1148 Hornby St)
        require prior registration. The Vancouver Art Gallery phase (9:00–11:00) is open
        to all — registration is welcome but not required. Please use the signup form or
        email us to confirm your spot for the IRCC building phase.
      </p>
    </div>

    <div class="event-quick-info">
      <div class="quick-info-item">
        <span class="quick-info-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"
            ></rect><line x1="16" y1="2" x2="16" y2="6"></line><line
              x1="8"
              y1="2"
              x2="8"
              y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg
          >
        </span>
        <span class="quick-info-text"><span class="lang-en">{eventPage.quickInfoDate.en}</span><span class="lang-zh">{eventPage.quickInfoDate.zh}</span><span class="lang-fr">{eventPage.quickInfoDate.fr}</span></span>
      </div>
      <div class="quick-info-divider"></div>
      <div class="quick-info-item">
        <span class="quick-info-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="12" cy="12" r="10"></circle><polyline
              points="12 6 12 12 16 14"></polyline></svg
          >
        </span>
        <span class="quick-info-text"><span class="lang-en">{eventPage.quickInfoTime.en}</span><span class="lang-zh">{eventPage.quickInfoTime.zh}</span><span class="lang-fr">{eventPage.quickInfoTime.fr}</span></span>
      </div>
      <div class="quick-info-divider"></div>
      <div class="quick-info-item">
        <span class="quick-info-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
            ></path><circle cx="12" cy="10" r="3"></circle></svg
          >
        </span>
        <span class="quick-info-text"><span class="lang-en">{eventPage.quickInfoPlace.en}</span><span class="lang-zh">{eventPage.quickInfoPlace.zh}</span><span class="lang-fr">{eventPage.quickInfoPlace.fr}</span></span>
      </div>
    </div>

    <div class="glance-card">
      <h4><span class="lang-en">{eventPage.whatToBringTitle.en}</span><span class="lang-zh">{eventPage.whatToBringTitle.zh}</span><span class="lang-fr">{eventPage.whatToBringTitle.fr}</span></h4>
      <ul>
        <li><span class="lang-en">{eventPage.whatToBring1.en}</span><span class="lang-zh">{eventPage.whatToBring1.zh}</span><span class="lang-fr">{eventPage.whatToBring1.fr}</span></li>
        <li><span class="lang-en">{eventPage.whatToBring2.en}</span><span class="lang-zh">{eventPage.whatToBring2.zh}</span><span class="lang-fr">{eventPage.whatToBring2.fr}</span></li>
        <li><span class="lang-en">{eventPage.whatToBring3.en}</span><span class="lang-zh">{eventPage.whatToBring3.zh}</span><span class="lang-fr">{eventPage.whatToBring3.fr}</span></li>
        <li><span class="lang-en">{eventPage.whatToBring4.en}</span><span class="lang-zh">{eventPage.whatToBring4.zh}</span><span class="lang-fr">{eventPage.whatToBring4.fr}</span></li>
        <li><span class="lang-en">{eventPage.whatToBring5.en}</span><span class="lang-zh">{eventPage.whatToBring5.zh}</span><span class="lang-fr">{eventPage.whatToBring5.fr}</span></li>
        <li><span class="lang-en">{eventPage.whatToBring6.en}</span><span class="lang-zh">{eventPage.whatToBring6.zh}</span><span class="lang-fr">{eventPage.whatToBring6.fr}</span></li>
        <li><span class="lang-en">{eventPage.whatToBring7.en}</span><span class="lang-zh">{eventPage.whatToBring7.zh}</span><span class="lang-fr">{eventPage.whatToBring7.fr}</span></li>
      </ul>
    </div>

    <div class="glance-card">
      <h4><span class="lang-en">{eventPage.guidelinesTitle.en}</span><span class="lang-zh">{eventPage.guidelinesTitle.zh}</span><span class="lang-fr">{eventPage.guidelinesTitle.fr}</span></h4>
      <ul>
        <li><span class="lang-en">{eventPage.guidelines1.en}</span><span class="lang-zh">{eventPage.guidelines1.zh}</span><span class="lang-fr">{eventPage.guidelines1.fr}</span></li>
        <li><span class="lang-en">{eventPage.guidelines2.en}</span><span class="lang-zh">{eventPage.guidelines2.zh}</span><span class="lang-fr">{eventPage.guidelines2.fr}</span></li>
        <li><span class="lang-en">{eventPage.guidelines3.en}</span><span class="lang-zh">{eventPage.guidelines3.zh}</span><span class="lang-fr">{eventPage.guidelines3.fr}</span></li>
        <li><span class="lang-en">{eventPage.guidelines4.en}</span><span class="lang-zh">{eventPage.guidelines4.zh}</span><span class="lang-fr">{eventPage.guidelines4.fr}</span></li>
        <li><span class="lang-en">{eventPage.guidelines5.en}</span><span class="lang-zh">{eventPage.guidelines5.zh}</span><span class="lang-fr">{eventPage.guidelines5.fr}</span></li>
        <li><span class="lang-en">{eventPage.guidelines6.en}</span><span class="lang-zh">{eventPage.guidelines6.zh}</span><span class="lang-fr">{eventPage.guidelines6.fr}</span></li>
        <li><span class="lang-en">{eventPage.guidelines7.en}</span><span class="lang-zh">{eventPage.guidelines7.zh}</span><span class="lang-fr">{eventPage.guidelines7.fr}</span></li>
      </ul>
    </div>

    <!-- Schedule (visible table follows global lang: data-lang on <html>) -->
    <div class="schedule-content glance-card" id="schedule-en">
      <table class="schedule-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Activity</th>
            <th>Details</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Phase 1</td>
            <td>Vancouver Art Gallery</td>
            <td>9:00 AM – 11:00 AM · 750 Hornby St</td>
          </tr>
          <tr>
            <td>8:45</td>
            <td>Setup</td>
            <td>Core team arrives early to set up</td>
          </tr>
          <tr>
            <td>9:00</td>
            <td>Gather</td>
            <td>Distribute materials and info cards</td>
          </tr>
          <tr>
            <td>9:15</td>
            <td>Opening</td>
            <td>Opening remarks and lead chants</td>
          </tr>
          <tr>
            <td>9:15–10:45</td>
            <td>Speakers & Chants</td>
            <td>Live social media coverage</td>
          </tr>
          <tr>
            <td>10:50</td>
            <td>March Assembly</td>
            <td>Assemble for march departure</td>
          </tr>
          <tr>
            <td>11:00</td>
            <td>🚶 March Departs</td>
            <td>From Art Gallery → IRCC (~10 min walk)</td>
          </tr>
          <tr class="highlight-row">
            <td>Phase 2</td>
            <td>IRCC Vancouver Office</td>
            <td>11:00 AM – 12:00 PM · 1148 Hornby St · ⚠️ Registration required</td>
          </tr>
          <tr>
            <td>11:10</td>
            <td>Arrival & Chants</td>
            <td>Arrive at 1148 Hornby and continue chants</td>
          </tr>
          <tr>
            <td>11:45</td>
            <td>Closing Remarks</td>
            <td>Closing remarks and next steps</td>
          </tr>
          <tr>
            <td>12:00</td>
            <td>Dispersal</td>
            <td>Orderly dispersal</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Chinese Schedule -->
    <div class="schedule-content glance-card" id="schedule-zh">
      <table class="schedule-table">
        <thead>
          <tr>
            <th>时间</th>
            <th>主要活动</th>
            <th>详情</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>第一阶段</td>
            <td>温哥华美术馆</td>
            <td>9:00 AM – 11:00 AM · 750 Hornby St</td>
          </tr>
          <tr>
            <td>8:45</td>
            <td>提前布置</td>
            <td>核心团队提前到场完成布置</td>
          </tr>
          <tr>
            <td>9:00</td>
            <td>集合</td>
            <td>发放物料和信息卡</td>
          </tr>
          <tr>
            <td>9:15</td>
            <td>开场发言</td>
            <td>开场讲话并领喊口号</td>
          </tr>
          <tr>
            <td>9:15–10:45</td>
            <td>发言与口号</td>
            <td>现场发言与口号，社交媒体直播同步</td>
          </tr>
          <tr>
            <td>10:50</td>
            <td>整队出发</td>
            <td>集合准备步行出发</td>
          </tr>
          <tr>
            <td>11:00</td>
            <td>🚶 游行开始</td>
            <td>从美术馆步行至 IRCC（约 10 分钟）</td>
          </tr>
          <tr class="highlight-row">
            <td>第二阶段</td>
            <td>IRCC 温哥华办公室</td>
            <td>11:00 AM – 12:00 PM · 1148 Hornby St · ⚠️ 需提前报名</td>
          </tr>
          <tr>
            <td>11:10</td>
            <td>抵达与口号</td>
            <td>抵达 1148 Hornby 并继续口号行动</td>
          </tr>
          <tr>
            <td>11:45</td>
            <td>结束发言</td>
            <td>总结发言并说明后续行动</td>
          </tr>
          <tr>
            <td>12:00</td>
            <td>有序散场</td>
            <td>活动有序结束</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- French Schedule -->
    <div class="schedule-content glance-card" id="schedule-fr">
      <table class="schedule-table">
        <thead>
          <tr>
            <th>Heure</th>
            <th>Activité</th>
            <th>Détails</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Phase 1</td>
            <td>Vancouver Art Gallery</td>
            <td>9 h 00 – 11 h 00 · 750 Hornby St</td>
          </tr>
          <tr>
            <td>8 h 45</td>
            <td>Préparation</td>
            <td>L’équipe principale arrive tôt pour l’installation</td>
          </tr>
          <tr>
            <td>9 h 00</td>
            <td>Rassemblement</td>
            <td>Distribution du matériel et des fiches d’information</td>
          </tr>
          <tr>
            <td>9 h 15</td>
            <td>Ouverture</td>
            <td>Discours d’ouverture et slogans menés par l’équipe</td>
          </tr>
          <tr>
            <td>9 h 15 – 10 h 45</td>
            <td>Interventions & slogans</td>
            <td>Couverture en direct sur les réseaux sociaux</td>
          </tr>
          <tr>
            <td>10 h 50</td>
            <td>Préparation de la marche</td>
            <td>Rassemblement avant le départ</td>
          </tr>
          <tr>
            <td>11 h 00</td>
            <td>🚶 Départ de la marche</td>
            <td>De la galerie vers IRCC (~10 minutes à pied)</td>
          </tr>
          <tr class="highlight-row">
            <td>Phase 2</td>
            <td>Bureau IRCC Vancouver</td>
            <td>11 h 00 – 12 h 00 · 1148 Hornby St · ⚠️ Inscription requise</td>
          </tr>
          <tr>
            <td>11 h 10</td>
            <td>Arrivée & slogans</td>
            <td>Arrivée au 1148 Hornby, slogans sur place</td>
          </tr>
          <tr>
            <td>11 h 45</td>
            <td>Clôture</td>
            <td>Remarques finales et prochaines étapes</td>
          </tr>
          <tr>
            <td>12 h 00</td>
            <td>Dispersion</td>
            <td>Dispersion ordonnée</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="event-cta-box">
      <h3><span class="lang-en">{eventPage.ctaTitle.en}</span><span class="lang-zh">{eventPage.ctaTitle.zh}</span><span class="lang-fr">{eventPage.ctaTitle.fr}</span></h3>
      <p><span class="lang-en">{eventPage.ctaText.en}</span><span class="lang-zh">{eventPage.ctaText.zh}</span><span class="lang-fr">{eventPage.ctaText.fr}</span></p>
      <div class="event-cta-buttons">
        <a href="/join" class="btn-cta btn-flip">
          <span class="btn-text-block">
            <span class="btn-text-wrapper">
              <span class="hover-out-text"><span class="lang-en">{eventPage.joinCampaign.en}</span><span class="lang-zh">{eventPage.joinCampaign.zh}</span><span class="lang-fr">{eventPage.joinCampaign.fr}</span></span>
              <span class="hover-in-text"><span class="lang-en">{eventPage.joinCampaign.en}</span><span class="lang-zh">{eventPage.joinCampaign.zh}</span><span class="lang-fr">{eventPage.joinCampaign.fr}</span></span>
            </span>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
