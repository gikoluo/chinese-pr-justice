---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="TOR528 2026 Mississauga Immigration Consultant Summit Action | Justice for Chinese PR Applicants">
  <section class="tor-hero">
    <div class="tor-hero-inner">
      <p class="tor-kicker">
        <span class="lang-en">TOR528 · Mississauga</span>
        <span class="lang-zh">TOR528 · 密西沙加</span>
        <span class="lang-fr">TOR528 · Mississauga</span>
      </p>
      <h2>
        <span class="lang-en">Immigration Consultant Summit Pop-up Action</span>
        <span class="lang-zh">密西沙加移民顾问峰会现场快闪活动</span>
        <span class="lang-fr">Action éclair au Sommet des consultants en immigration</span>
      </h2>
      <p class="tor-hero-copy">
        <span class="lang-en">A peaceful public action calling for fair, transparent, and timely PR security-screening decisions.</span>
        <span class="lang-zh">一次和平的公共区域行动，呼吁永久居民安调审理公平、透明、及时。</span>
        <span class="lang-fr">Une action publique pacifique pour demander des décisions équitables, transparentes et rapides sur les vérifications de sécurité des demandes de RP.</span>
      </p>
    </div>
  </section>

  <section class="tor-event">
    <div class="container">
      <div class="tor-alert">
        <strong>
          <span class="lang-en">Check-in required</span>
          <span class="lang-zh">需要签到</span>
          <span class="lang-fr">Présence à confirmer sur place</span>
        </strong>
        <span>
          <span class="lang-en">Please check in with organizers when you arrive. Detailed run-of-show is TBD.</span>
          <span class="lang-zh">到场后请向组织者签到。具体日程安排待定。</span>
          <span class="lang-fr">Veuillez vous présenter aux organisateurs à votre arrivée. Le déroulé détaillé reste à confirmer.</span>
        </span>
      </div>

      <div class="tor-summary-grid">
        <div class="tor-summary-card">
          <span class="tor-summary-label">
            <span class="lang-en">Date</span>
            <span class="lang-zh">日期</span>
            <span class="lang-fr">Date</span>
          </span>
          <strong>
            <span class="lang-en">Thursday, May 28, 2026</span>
            <span class="lang-zh">2026年5月28日 周四</span>
            <span class="lang-fr">Jeudi 28 mai 2026</span>
          </strong>
        </div>
        <div class="tor-summary-card">
          <span class="tor-summary-label">
            <span class="lang-en">Time</span>
            <span class="lang-zh">时间</span>
            <span class="lang-fr">Heure</span>
          </span>
          <strong>
            <span class="lang-en">7:30 AM – 11:30 AM</span>
            <span class="lang-zh">上午7:30 – 上午11:30</span>
            <span class="lang-fr">7 h 30 – 11 h 30</span>
          </strong>
        </div>
        <div class="tor-summary-card">
          <span class="tor-summary-label">
            <span class="lang-en">Format</span>
            <span class="lang-zh">形式</span>
            <span class="lang-fr">Format</span>
          </span>
          <strong>
            <span class="lang-en">Two public-area stops</span>
            <span class="lang-zh">两个公共区域点位</span>
            <span class="lang-fr">Deux lieux publics</span>
          </strong>
        </div>
      </div>

      <div class="tor-section-heading">
        <p class="tor-kicker tor-kicker-dark">
          <span class="lang-en">Action Route</span>
          <span class="lang-zh">行动路线</span>
          <span class="lang-fr">Itinéraire</span>
        </p>
        <h2>
          <span class="lang-en">From the summit hotel area to the Mississauga IRCC office</span>
          <span class="lang-zh">从峰会酒店外公共区域到密西沙加 IRCC 办公室</span>
          <span class="lang-fr">De l’hôtel du sommet au bureau d’IRCC à Mississauga</span>
        </h2>
      </div>

      <div class="tor-route-grid">
        <article class="tor-stop-card">
          <div class="tor-stop-time">7:30–10:00</div>
          <h3>
            <span class="lang-en">Summit Hotel Public Area</span>
            <span class="lang-zh">移民顾问峰会酒店外公共区域</span>
            <span class="lang-fr">Espace public à l’extérieur de l’hôtel du sommet</span>
          </h3>
          <p>6750 Mississauga Rd, Mississauga, ON L5N 2L3</p>
        </article>

        <article class="tor-stop-card tor-stop-card-red">
          <div class="tor-stop-time">10:45–11:30</div>
          <h3>
            <span class="lang-en">Mississauga IRCC Office Public Area</span>
            <span class="lang-zh">密西沙加 IRCC 办公室外公共区域</span>
            <span class="lang-fr">Espace public devant le bureau d’IRCC à Mississauga</span>
          </h3>
          <p>Citizenship and Immigration Canada Office, 3085 Glen Erin Dr, Mississauga, ON L5L 1J3</p>
        </article>
      </div>

      <div class="tor-map-card">
        <div class="tor-map-header">
          <h2>
            <span class="lang-en">Route Map</span>
            <span class="lang-zh">路线图</span>
            <span class="lang-fr">Carte de l’itinéraire</span>
          </h2>
          <a
            href="https://www.google.com/maps/dir/?api=1&origin=6750%20Mississauga%20Rd%2C%20Mississauga%2C%20ON%20L5N%202L3&destination=3085%20Glen%20Erin%20Dr%2C%20Mississauga%2C%20ON%20L5L%201J3"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="lang-en">Open in Google Maps</span>
            <span class="lang-zh">在 Google 地图中打开</span>
            <span class="lang-fr">Ouvrir dans Google Maps</span>
          </a>
        </div>
        <iframe
          title="TOR528 route map from 6750 Mississauga Road to 3085 Glen Erin Drive"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?output=embed&saddr=6750%20Mississauga%20Rd%2C%20Mississauga%2C%20ON%20L5N%202L3&daddr=3085%20Glen%20Erin%20Dr%2C%20Mississauga%2C%20ON%20L5L%201J3"
        ></iframe>
      </div>

      <div class="tor-info-grid">
        <section class="tor-info-panel">
          <h2>
            <span class="lang-en">Tentative Schedule</span>
            <span class="lang-zh">暂定日程</span>
            <span class="lang-fr">Horaire provisoire</span>
          </h2>
          <div class="tor-schedule-list">
            <div class="tor-schedule-row">
              <span>7:30</span>
              <p>
                <span class="lang-en">Arrival, check-in, and setup</span>
                <span class="lang-zh">到场、签到、现场准备</span>
                <span class="lang-fr">Arrivée, confirmation de présence et installation</span>
              </p>
            </div>
            <div class="tor-schedule-row">
              <span>7:30–10:00</span>
              <p>
                <span class="lang-en">Public-area visibility action outside the summit hotel</span>
                <span class="lang-zh">峰会酒店外公共区域快闪行动</span>
                <span class="lang-fr">Action de visibilité dans l’espace public devant l’hôtel du sommet</span>
              </p>
            </div>
            <div class="tor-schedule-row">
              <span>10:00–10:45</span>
              <p>
                <span class="lang-en">Transition to the Mississauga IRCC office</span>
                <span class="lang-zh">转场前往密西沙加 IRCC 办公室</span>
                <span class="lang-fr">Déplacement vers le bureau d’IRCC à Mississauga</span>
              </p>
            </div>
            <div class="tor-schedule-row">
              <span>10:45–11:30</span>
              <p>
                <span class="lang-en">Public-area action outside the IRCC office</span>
                <span class="lang-zh">IRCC 办公室外公共区域行动</span>
                <span class="lang-fr">Action dans l’espace public devant le bureau d’IRCC</span>
              </p>
            </div>
          </div>
          <p class="tor-note">
            <span class="lang-en">Detailed speaking order, chants, and media moments are TBD.</span>
            <span class="lang-zh">发言顺序、口号安排和媒体环节待定。</span>
            <span class="lang-fr">L’ordre des interventions, les slogans et les moments médias restent à confirmer.</span>
          </p>
        </section>

        <section class="tor-info-panel">
          <h2>
            <span class="lang-en">Participant Notes</span>
            <span class="lang-zh">参与者须知</span>
            <span class="lang-fr">Notes aux participants</span>
          </h2>
          <ul>
            <li>
              <span class="lang-en">Stay in public areas and follow organizer guidance.</span>
              <span class="lang-zh">请停留在公共区域，并听从组织者现场指引。</span>
              <span class="lang-fr">Restez dans les espaces publics et suivez les consignes des organisateurs.</span>
            </li>
            <li>
              <span class="lang-en">Keep signs clear, respectful, and focused on PR processing fairness.</span>
              <span class="lang-zh">标语请保持清晰、克制，并聚焦 PR 审理公平。</span>
              <span class="lang-fr">Gardez les affiches claires, respectueuses et centrées sur l’équité du traitement des demandes de RP.</span>
            </li>
            <li>
              <span class="lang-en">Bring water, weather-appropriate clothing, and portable phone power.</span>
              <span class="lang-zh">请携带饮水、适合天气的衣物和手机移动电源。</span>
              <span class="lang-fr">Apportez de l’eau, des vêtements adaptés à la météo et une batterie externe.</span>
            </li>
            <li>
              <span class="lang-en">Do not block entrances, roads, sidewalks, or emergency access.</span>
              <span class="lang-zh">不要阻挡入口、道路、人行道或紧急通道。</span>
              <span class="lang-fr">Ne bloquez pas les entrées, les routes, les trottoirs ou les accès d’urgence.</span>
            </li>
          </ul>
        </section>
      </div>

      <div class="tor-cta">
        <h2>
          <span class="lang-en">Join the TOR528 action</span>
          <span class="lang-zh">加入 TOR528 行动</span>
          <span class="lang-fr">Participez à l’action TOR528</span>
        </h2>
        <p>
          <span class="lang-en">If you plan to attend, please connect with organizers so we can coordinate check-in, materials, and location updates.</span>
          <span class="lang-zh">如果你计划参加，请先联系组织者，方便协调签到、物料和地点更新。</span>
          <span class="lang-fr">Si vous prévoyez participer, communiquez avec les organisateurs afin de coordonner la présence, le matériel et les mises à jour de lieu.</span>
        </p>
        <a href="/join" class="tor-cta-link">
          <span class="lang-en">Contact organizers</span>
          <span class="lang-zh">联系组织者</span>
          <span class="lang-fr">Contacter les organisateurs</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tor-hero {
    background:
      linear-gradient(125deg, rgba(15, 23, 42, 0.96), rgba(30, 58, 138, 0.9) 52%, rgba(185, 28, 28, 0.78)),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      #1e3a8a;
    background-size: auto, 72px 72px, auto;
    color: #ffffff;
    padding: 7rem 1.5rem 5.5rem;
    text-align: center;
  }

  .tor-hero-inner {
    max-width: 880px;
    margin: 0 auto;
  }

  .tor-kicker {
    display: inline-flex;
    padding: 0.35rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    margin: 0 0 0.75rem;
    background: rgba(15, 23, 42, 0.35);
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .tor-kicker-dark {
    border-color: rgba(185, 28, 28, 0.28);
    background: rgba(185, 28, 28, 0.12);
    color: #fecaca;
  }

  .tor-hero h2 {
    margin: 0;
    font-family: var(--font-section-heading);
    color: #ffffff;
    font-size: clamp(2.2rem, 5vw, 4.2rem);
    line-height: 1.05;
  }

  .tor-hero-copy {
    max-width: 760px;
    margin: 1.1rem auto 0;
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .tor-event {
    background:
      linear-gradient(180deg, #0f172a 0, #1e3a8a 18rem, #334155 18rem, #0f172a 100%);
    padding: 3.5rem 0;
  }

  .tor-alert {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-left: 5px solid #b91c1c;
    background: rgba(15, 23, 42, 0.78);
    color: rgba(255, 255, 255, 0.88);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.24);
  }

  .tor-alert strong {
    color: #fecaca;
    white-space: nowrap;
  }

  .tor-summary-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .tor-summary-card,
  .tor-stop-card,
  .tor-info-panel,
  .tor-map-card,
  .tor-cta {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(248, 250, 252, 0.94);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
  }

  .tor-summary-card {
    position: relative;
    overflow: hidden;
    padding: 1.25rem;
    background: linear-gradient(145deg, #ffffff, #e0e7ff);
  }

  .tor-summary-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    background: #b91c1c;
  }

  .tor-summary-label {
    display: block;
    margin-bottom: 0.4rem;
    color: #64748b;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .tor-summary-card strong {
    color: #1e3a8a;
    font-size: 1rem;
    line-height: 1.45;
  }

  .tor-section-heading {
    max-width: 760px;
    margin: 3rem auto 1.3rem;
    text-align: center;
  }

  .tor-section-heading h2 {
    color: #ffffff;
  }

  .tor-event .tor-section-heading h2 {
    color: #ffffff;
  }

  .tor-section-heading h2,
  .tor-info-panel h2,
  .tor-map-header h2,
  .tor-cta h2 {
    margin: 0;
    font-family: var(--font-heading);
    color: #0f172a;
  }

  .tor-route-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .tor-stop-card {
    padding: 1.4rem;
    border-top: 0;
    background: linear-gradient(145deg, #1e3a8a, #334155);
    color: #ffffff;
  }

  .tor-stop-card-red {
    background: linear-gradient(145deg, #334155, #b91c1c);
  }

  .tor-stop-time {
    display: inline-flex;
    margin-bottom: 0.75rem;
    padding: 0.35rem 0.6rem;
    background: rgba(255, 255, 255, 0.16);
    color: #ffffff;
    font-weight: 800;
    font-size: 0.86rem;
  }

  .tor-stop-card-red .tor-stop-time {
    background: rgba(255, 255, 255, 0.18);
  }

  .tor-stop-card h3 {
    margin: 0 0 0.7rem;
    color: #ffffff;
    font-size: 1.18rem;
  }

  .tor-stop-card p {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.6;
  }

  .tor-map-card {
    margin-top: 1.5rem;
    overflow: hidden;
    background: #0f172a;
  }

  .tor-map-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    background: linear-gradient(90deg, #1e3a8a, #334155);
  }

  .tor-map-header h2 {
    color: #ffffff;
  }

  .tor-map-header a {
    padding: 0.45rem 0.7rem;
    background: #ffffff;
    color: #1e3a8a;
    font-weight: 800;
    text-decoration: none;
  }

  .tor-map-header a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .tor-map-card iframe {
    display: block;
    width: 100%;
    height: 430px;
    border: 0;
  }

  .tor-info-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: 1rem;
  }

  .tor-info-panel {
    padding: 1.4rem;
    background: linear-gradient(180deg, #f8fafc, #e2e8f0);
  }

  .tor-info-panel h2 {
    color: #1e3a8a;
  }

  .tor-schedule-list {
    margin-top: 1rem;
    display: grid;
    gap: 0.75rem;
  }

  .tor-schedule-row {
    display: grid;
    grid-template-columns: 7rem minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(30, 58, 138, 0.14);
  }

  .tor-schedule-row span:first-child {
    color: #1e3a8a;
    font-weight: 900;
  }

  .tor-schedule-row p {
    margin: 0;
    color: #334155;
    line-height: 1.55;
  }

  .tor-note {
    margin: 1rem 0 0;
    padding: 0.8rem 0.9rem;
    background: rgba(185, 28, 28, 0.1);
    border-left: 4px solid #b91c1c;
    color: #b91c1c;
    font-weight: 700;
  }

  .tor-info-panel ul {
    margin: 1rem 0 0;
    padding-left: 1.2rem;
    color: #334155;
  }

  .tor-info-panel li {
    margin-bottom: 0.8rem;
    line-height: 1.6;
  }

  .tor-cta {
    margin-top: 1.5rem;
    padding: 2rem;
    text-align: center;
    background: linear-gradient(135deg, #1e3a8a, #0f172a 55%, #b91c1c);
    color: #ffffff;
  }

  .tor-cta h2 {
    color: #ffffff;
  }

  .tor-cta p {
    max-width: 720px;
    margin: 0.75rem auto 1.3rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
  }

  .tor-cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.78rem 1.2rem;
    background: #b91c1c;
    color: #ffffff;
    font-weight: 800;
    text-decoration: none;
  }

  .tor-cta-link:hover {
    background: #991b1b;
  }

  @media (max-width: 860px) {
    .tor-summary-grid,
    .tor-route-grid,
    .tor-info-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .tor-alert,
    .tor-map-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 560px) {
    .tor-hero {
      padding: 4.5rem 1rem 3.5rem;
    }

    .tor-event {
      padding: 2.25rem 0;
    }

    .tor-schedule-row {
      grid-template-columns: minmax(0, 1fr);
      gap: 0.25rem;
    }

    .tor-map-card iframe {
      height: 340px;
    }
  }
</style>
