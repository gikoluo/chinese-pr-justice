---
// EventPhotos Section component (EN + 中文)
import { eventPhotosSection } from '../i18n/strings';

// March 13, 2026 procession photos (manually curated)
const march13Photos = [
  'march13-01-DSC00903.jpg', 'march13-02-DSC00904.jpg', 'march13-03-DSC00905.jpg', 'march13-08-DSC00910.jpg', 'march13-09-DSC00911.jpg',
  'march13-11-DSC00913.jpg', 'march13-18-DSC00925.jpg', 'march13-22-DSC00931.jpg', 'march13-23-DSC00940.jpg', 'march13-24-DSC00933.jpg',
  'march13-26-DSC00938.jpg', 'march13-27-DSC00937.jpg', 'march13-28-DSC00941.jpg', 'march13-29-DSC00943.jpg',
];
---

<section id="photos" class="photos-section">
  <div class="container">
    <h2>
      <span class="lang-en">{eventPhotosSection.title.en}</span><span class="lang-zh">{eventPhotosSection.title.zh}</span><span class="lang-fr">{eventPhotosSection.title.fr}</span>
    </h2>
    <p class="section-intro">
      <span class="lang-en">{eventPhotosSection.intro.en}</span><span class="lang-zh">{eventPhotosSection.intro.zh}</span><span class="lang-fr">{eventPhotosSection.intro.fr}</span>
    </p>

    <div class="photos-grid photos-grid-march13">
      {march13Photos.map((file) => (
        <figure class="photo-card">
          <img src={`/events/march-13-2026/${file}`} alt="Procession to Parliament Hill, March 13, 2026" loading="lazy" />
        </figure>
      ))}
    </div>

    <div class="photos-grid photos-grid-video">
      <figure class="photo-card photo-card-video">
        <video controls preload="metadata">
          <source src="/events/6186.MP4" type="video/mp4" />
          <span class="lang-en">Your browser does not support the video tag.</span>
          <span class="lang-zh">您的浏览器不支持视频播放。</span>
          <span class="lang-fr">Votre navigateur ne prend pas en charge la lecture vidéo.</span>
        </video>
      </figure>
    </div>
  </div>
</section>

<style>
  .photos-section {
    background: var(--bg-light);
  }

  .photos-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .photos-grid-video {
    margin-top: 1.5rem;
    max-width: 640px;
  }

  .photo-card {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 6px 18px rgba(15, 31, 51, 0.35);
  }

  .photo-card img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .photo-card-video video {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (max-width: 900px) {
    .photos-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .photos-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
